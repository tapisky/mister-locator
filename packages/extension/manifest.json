{
  "manifest_version": 3,
  "name": "Mister Locator",
  "version": "1.0.0",
  "description": "Extract robust Playwright locators from any element on the page.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mister Locator"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
